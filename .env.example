# ─── 第三方 API 凭据 ──────────────────────────────
SHILIU_API_KEY=your_shiliu_key_here
SHILIU_BASE_URL=https://api.16ai.chat/api/v1

DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

DEFAULT_AVATAR_ID=
DEFAULT_SPEAKER_ID=

QINGDOU_API_KEY=your_qingdou_key_here
QINGDOU_BASE_URL=https://www.qingdou.vip/web/api

APIMART_API_KEY=your_apimart_key_here
APIMART_BASE_URL=https://api.apimart.ai/v1

# ─── Phase 2 防腐层 env(v0.6.3 / v1.0 §1.4)──────────
# 部署模式:dev = 本机开发,prod = Mac mini 团队版
# - dev (默认): CORS 自动放本机 http://localhost:8001 + http://127.0.0.1:8001
# - prod:必须设 ALLOWED_ORIGIN,且不允许写 "*",否则启动 raise CorsConfigError
APP_ENV=dev

# CORS 允许 origin
# - 多个用逗号分隔,e.g. ALLOWED_ORIGIN=https://a.com,https://b.com
# - dev 下追加 (默认本机已放行,这里放公司测试域名等)
# - prod 下必填,不能写 "*"
ALLOWED_ORIGIN=https://gongchang.poju.ai

# 写操作管理 token(Phase 3 security)
# - 未设:本机旧行为,任何人能 POST/DELETE。启动会打 warning。
# - 设了:所有 POST/PUT/PATCH/DELETE(除 /api/health /docs /media /skills)
#         都必须带 HTTP header  X-Admin-Token: <值>,否则 401。
# - 前端从 localStorage.admin_token 读后自动带 header,不要硬编码到代码里。
# - 推荐生成方式:python -c "import secrets; print(secrets.token_urlsafe(32))"
# ADMIN_TOKEN=

# 媒体 URL 前缀(空串 = 同源相对路径,本机调试可填 http://127.0.0.1:8000)
MEDIA_PUBLIC_BASE=

# Claude / Opus proxy(本机 Claude Code 启动后给后端调用)
OPUS_BASE_URL=http://localhost:3456/v1

# 资产根目录(可选 override,默认走代码内的 ~/Desktop/* 路径)
# DATA_DIR=
# KB_ROOT=
# ASSETS_LIB_ROOT=

# Skill 仓库根目录(v1.1 增补)
# 开发机:不设,默认 ~/Desktop/skills (skill 平铺子目录)
# Mac mini:设 ~/Desktop/skills/团队版 (symlink 视图,团队版 → ~/skills-source/)
# SKILL_ROOT=
